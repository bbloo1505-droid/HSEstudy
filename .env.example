# Personal study tool — easiest setup is a cloud OpenAI-compatible key.
# Copy to .env.local and fill in.

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Optional (OpenAI-compatible providers):
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional local fallback instead of cloud:
# OLLAMA_HOST=http://127.0.0.1:11434
